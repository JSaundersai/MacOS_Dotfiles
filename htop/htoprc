# Htop Configuration
# Display fields: PID, Command, User, CPU%, MEM%, Time, State, etc.
fields=0 48 17 18 38 39 40 2 46 47 49 1

# Sort by memory usage (descending)
sort_key=46
sort_direction=1

# Display settings
tree_view=0
header_margin=1
detailed_cpu_time=0
cpu_count_from_zero=0
update_process_names=0
account_guest_in_cpu_meter=0

# Color scheme (0=default, 1=monochrome, 2=black on white)
color_scheme=0

# Refresh rate (in tenths of a second, 15 = 1.5 seconds)
delay=15
# Left side meters (CPU, Memory, Swap)
left_meters=LeftCPUs2 Memory Swap
left_meter_modes=1 1 1

# Right side meters (CPU, Tasks, Load Average, Uptime)
right_meters=RightCPUs2 Tasks LoadAverage Uptime
right_meter_modes=1 2 2 2
# Process filtering
hide_kernel_threads=1
hide_userland_threads=0
shadow_other_users=0
show_thread_names=0
show_program_path=1

# Highlighting
highlight_base_name=0
highlight_megabytes=1
highlight_threads=1
tree_view_always_by_pid=0
header_layout=two_6_58_11
column_meters_0=AllCPUs Memory Swap
column_meter_modes_0=2 2 2
column_meters_1=Tasks
column_meter_modes_1=2
